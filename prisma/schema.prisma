// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                    String   @id @default(uuid()) @db.Uuid
  razon_social          String   @db.VarChar(200)
  nombre_comercial      String?  @db.VarChar(200)
  rfc                   String   @db.VarChar(13)
  domicilio_fiscal      String?  @db.Text
  ciudad                String?  @db.VarChar(100)
  estado                String?  @db.VarChar(100)
  telefono              String?  @db.VarChar(20)
  correo_electronico    String?  @db.VarChar(200)
  pagina_web            String?  @db.VarChar(200)
  numero_empleados      Int?
  empleados_permanentes Int?
  empleados_eventuales  Int?
  created_at            DateTime @default(now())

  @@map("empresas")
}

model Documento {
  id               String   @id @default(uuid()) @db.Uuid
  document_type    String   @db.VarChar(50)
  file_name        String   @db.VarChar(500)
  s3_url           String   @db.Text
  s3_key           String   @db.VarChar(500)
  mime_type        String   @db.VarChar(50)
  file_size        Int
  extracted_data   Json?
  textract_error   String?  @db.Text
  created_at       DateTime @default(now())

  @@map("documentos")
}
